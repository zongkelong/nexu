{
  "name": "@nexu/desktop",
  "version": "0.1.12",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main/bootstrap.js",
  "description": "Electron desktop shell for Nexu local runtime",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start:electron": "node -e \"console.error('Use pnpm dev start desktop from the nexu project root after starting openclaw/controller/web as needed.'); process.exit(1)\"",
    "prepare:controller-sidecar": "node ./scripts/prepare-controller-sidecar.mjs",
    "prepare:openclaw-sidecar": "node ./scripts/prepare-openclaw-sidecar.mjs",
    "prepare:runtime-sidecars": "node ./scripts/prepare-runtime-sidecars.mjs",
    "prepare:web-sidecar": "node ./scripts/prepare-web-sidecar.mjs",
    "package:sidecars": "node ./scripts/prepare-runtime-sidecars.mjs --release",
    "dist:mac": "node ./scripts/dist-mac.mjs",
    "dist:mac:arm64": "NEXU_DESKTOP_TARGET_ARCH=arm64 node ./scripts/dist-mac.mjs",
    "dist:mac:x64": "NEXU_DESKTOP_TARGET_ARCH=x64 node ./scripts/dist-mac.mjs",
    "dist:mac:unsigned": "node ./scripts/dist-mac.mjs --unsigned",
    "dist:win": "node ./scripts/dist-win.mjs",
    "dist:win:local": "node ./scripts/dist-win-stage.mjs --local",
    "dist:win:unsigned": "node ./scripts/dist-win-stage.mjs --target=dir",
    "dist:mac:unsigned:arm64": "NEXU_DESKTOP_TARGET_ARCH=arm64 node ./scripts/dist-mac.mjs --unsigned",
    "dist:mac:unsigned:x64": "NEXU_DESKTOP_TARGET_ARCH=x64 node ./scripts/dist-mac.mjs --unsigned",
    "upload:sourcemaps": "node ./scripts/upload-sourcemaps.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexu/shared": "workspace:*",
    "@nexu/slimclaw": "workspace:*",
    "@sentry/electron": "^7.10.0",
    "electron-updater": "^6.3.9",
    "pino": "^10.3.1",
    "sharp": "0.34.5",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@amplitude/unified": "1.0.0-beta.38",
    "@electron/notarize": "^3.1.0",
    "@hey-api/client-fetch": "^0.8.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@tanstack/react-query": "^5.66.9",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "lucide-react": "^0.474.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.0",
    "sonner": "^2.0.1",
    "tailwindcss": "^4.0.0",
    "tailwind-merge": "^3.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "toolsets": {
      "winCodeSign": "1.0.0"
    },
    "appId": "io.nexu.desktop",
    "productName": "Nexu",
    "icon": "build/icon.icns",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/openclaw",
      "!node_modules/openclaw/**/*",
      "!node_modules/sharp",
      "!node_modules/sharp/**/*",
      "!node_modules/@img",
      "!node_modules/@img/**/*"
    ],
    "extraResources": [
      {
        "from": ".dist-runtime",
        "to": "runtime"
      },
      {
        "from": "static/bundled-skills",
        "to": "static/bundled-skills"
      },
      {
        "from": "../controller/static/platform-templates",
        "to": "static/platform-templates"
      },
      {
        "from": "node_modules/sharp",
        "to": "bundled-node-modules/sharp"
      },
      {
        "from": "node_modules/@img",
        "to": "bundled-node-modules/@img"
      },
      {
        "from": "build-config.json",
        "to": "build-config.json",
        "filter": ["**/*"]
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "build/icon.ico",
        "to": "tray-icon.ico"
      },
      {
        "from": "build/tray-icon-mac.png",
        "to": "tray-icon-mac.png"
      }
    ],
    "afterSign": "./scripts/notarize.cjs",
    "copyright": "Copyright © 2026 Powerformer, Inc.",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "artifactName": "nexu-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "artifactName": "nexu-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false,
      "artifactName": "nexu-setup-${version}-${arch}.${ext}"
    },
    "dmg": {
      "size": "2g"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nexu-io",
        "repo": "nexu"
      }
    ]
  }
}
