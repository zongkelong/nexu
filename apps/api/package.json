{
  "name": "@nexu/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=development tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-openapi": "tsx scripts/generate-openapi.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed-dev.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/zod-openapi": "^0.18.4",
    "@nexu/shared": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "better-auth": "^1.2.7",
    "dd-trace": "^5.87.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.5",
    "pg": "^8.13.1",
    "resend": "^6.9.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
