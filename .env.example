# Database (PostgreSQL via docker-compose)
DATABASE_URL=postgresql://nexu:nexu@localhost:5433/nexu_dev

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional for dev, required for production)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption (AES-256-GCM, 32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Gateway
GATEWAY_TOKEN=gw-secret-token
INTERNAL_TRPC_TOKEN=change-me-internal-token

# Slack OAuth (shared app)
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Server
PORT=3000
WEB_URL=http://localhost:5173
INTERNAL_API_TOKEN=change-me-internal-token

# Runtime Sidecar (Pool Node)
RUNTIME_POOL_ID=default
RUNTIME_API_BASE_URL=http://localhost:3000
RUNTIME_POD_IP=127.0.0.1
OPENCLAW_CONFIG_PATH=/tmp/openclaw/config.json
OPENCLAW_STATE_DIR=/tmp/openclaw/state
OPENCLAW_GATEWAY_READY_URL=http://localhost:18789/health

# Runtime tuning (optional)
RUNTIME_POLL_INTERVAL_MS=2000
RUNTIME_POLL_JITTER_MS=300
RUNTIME_MAX_BACKOFF_MS=30000
RUNTIME_REQUEST_TIMEOUT_MS=3000
RUNTIME_HEARTBEAT_INTERVAL_MS=5000
