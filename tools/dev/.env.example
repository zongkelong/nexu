# tools/dev orchestration contract
# This file is the source of truth for cross-service local-dev injection.

# tools/dev control-plane logging
NEXU_DEV_LOG_LEVEL=info
NEXU_DEV_LOG_PRETTY=false

# Core ports and URLs
NEXU_DEV_CONTROLLER_PORT=50800
NEXU_DEV_WEB_PORT=50810
NEXU_DEV_OPENCLAW_PORT=18789
NEXU_DEV_DESKTOP_HOST=127.0.0.1
NEXU_DEV_DESKTOP_PORT=5180
NEXU_DEV_CONTROLLER_URL=http://127.0.0.1:50800
NEXU_DEV_WEB_URL=http://127.0.0.1:50810
NEXU_DEV_OPENCLAW_BASE_URL=http://127.0.0.1:18789
NEXU_DEV_DESKTOP_SERVER_URL=http://127.0.0.1:5180

# Repo-scoped local runtime state
NEXU_DEV_NEXU_HOME_DIR=.tmp/dev/nexu-home
NEXU_DEV_OPENCLAW_STATE_DIR=.tmp/dev/openclaw/state
NEXU_DEV_OPENCLAW_CONFIG_PATH=.tmp/dev/openclaw/state/openclaw.json
NEXU_DEV_OPENCLAW_LOG_DIR=.tmp/dev/openclaw/logs

# OpenClaw process entry and logging
# Optional override. Leave unset to use the slimclaw-managed prepared runtime entry.
# NEXU_DEV_OPENCLAW_ENTRY_PATH=packages/slimclaw/.dist-runtime/openclaw/node_modules/openclaw/openclaw.mjs
NEXU_DEV_OPENCLAW_LOG_LEVEL=info
NEXU_DEV_OPENCLAW_GATEWAY_TOKEN=gw-secret-token
